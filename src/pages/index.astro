  <title>For Bethany</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      min-height: 100%;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    body {
      background: #fff;
      color: #111;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 16px;
      line-height: 1.7;
      width: 100%;
      max-width: 560px;
      padding: 32px 24px 48px;
    }

    /* ── Ornament & Header ── */
    .ornament {
      text-align: center;
      font-size: 20px;
      letter-spacing: 10px;
      color: #888;
      margin-bottom: 12px;
    }

    h1 {
      font-size: 32px;
      font-weight: normal;
      text-align: center;
      letter-spacing: 0.03em;
      line-height: 1.2;
    }

    .tagline {
      text-align: center;
      font-style: italic;
      color: #555;
      font-size: 15px;
      margin-top: 6px;
      margin-bottom: 28px;
    }

    /* ── Tab radio inputs (hidden) ── */
    input[name="tab"] {
      display: none;
    }

    /* ── Navigation ── */
    nav {
      display: flex;
      border-top: 1px solid #ccc;
      border-bottom: 1px solid #ccc;
      margin-bottom: 28px;
    }

    nav label {
      flex: 1;
      text-align: center;
      padding: 10px 4px;
      color: #555;
      font-size: 13px;
      letter-spacing: 0.1em;
      font-family: Georgia, serif;
      border-bottom: 2px solid transparent;
      cursor: pointer;
    }

    /* ── Active tab label ── */
    #tab-home:checked  ~ nav label[for="tab-home"],
    #tab-list:checked  ~ nav label[for="tab-list"],
    #tab-quote:checked ~ nav label[for="tab-quote"],
    #tab-secret:checked ~ nav label[for="tab-secret"] {
      color: #111;
      border-bottom-color: #111;
    }

    /* ── Divider ── */
    hr {
      border: none;
      border-top: 1px solid #ddd;
      margin: 24px 0;
    }

    /* ── Section Label ── */
    .label {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 12px;
    }

    /* ── Sections: hidden by default, shown via checked radio ── */
    section {
      display: none;
    }

    #tab-home:checked  ~ #home,
    #tab-list:checked  ~ #list,
    #tab-quote:checked ~ #quote,
    #tab-secret:checked ~ #secret {
      display: block;
    }

    /* ── Home ── */
    #home, #list, #quote, #secret {
      padding: 0 16px;
    }
    

    /* ── Love Note ── */
    .note {
      font-style: italic;
      font-size: 17px;
      line-height: 1.85;
      color: #222;
    }

    .note-footer {
      margin-top: 20px;
      font-size: 14px;
      color: #555;
      text-align: right;
    }

    /* ── Reading List ── */
    .book {
      display: flex;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid #eee;
      align-items: flex-start;
    }

    .spine {
      width: 7px;
      min-height: 52px;
      background: #222;
      border-radius: 1px;
      flex-shrink: 0;
      margin-top: 4px;
    }

    .book-title {
      font-size: 16px;
      font-weight: bold;
      line-height: 1.3;
      margin-bottom: 4px;
    }

    .book-author {
      font-size: 13px;
      color: #555;
      font-style: italic;
    }

    .book-note {
      font-size: 12px;
      color: #888;
      margin-top: 4px;
    }

    .amazon-btn {
      display: inline-block;
      margin-top: 8px;
      padding: 8px 16px;
      background: #111;
      color: #fff;
      font-family: Georgia, serif;
      font-size: 13px;
      text-decoration: none;
      letter-spacing: 0.05em;
      border: none;
      cursor: pointer;
    }

    .amazon-btn:hover {
      background: #333;
    }

    /* ── Quote ── */
    .quote-item {
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid #eee;
    }

    .quote-item:last-child {
      border-bottom: none;
    }

    blockquote {
      border-left: 2px solid #333;
      padding: 4px 0 4px 18px;
      margin: 0 0 8px;
    }

    blockquote p {
      font-style: italic;
      font-size: 16px;
      line-height: 1.75;
      color: #222;
    }

    .quote-source {
      font-size: 13px;
      color: #666;
      padding-left: 18px;
    }

    /* ── Hidden Message ── */
    .secret {
      font-size: 15px;
      line-height: 1.85;
      color: #222;
    }

    .secret-footer {
      margin-top: 24px;
      font-style: italic;
      font-size: 14px;
      color: #888;
      text-align: center;
    }

    /* ── Page Footer ── */
    footer {
      text-align: center;
      margin-top: 48px;
      font-size: 12px;
      color: #bbb;
      letter-spacing: 0.05em;
    }
  </style>
</head>
<body>

<div class="ornament">— ✦ —</div>
<h1>Dear My Love</h1>
<p class="tagline">a little something, made with love for you</p>

<!-- Tab state controllers — must be siblings before nav and sections -->
<input type="radio" name="tab" id="tab-home" checked />
<input type="radio" name="tab" id="tab-list" />
<input type="radio" name="tab" id="tab-quote" />
<input type="radio" name="tab" id="tab-secret" />

<nav>
  <label for="tab-home">Home</label>
  <label for="tab-list">Reading list</label>
  <label for="tab-quote">Quote</label>
  <label for="tab-secret">✦</label>
</nav>

<!-- HOME -->
<section id="home">
  <p class="label">A note for you</p>
  <p class="note">
    Every great love story begins with a book —<br>
    or so they say.<br><br>
    This Kindle is yours now.<br>
    Fill it with worlds, words, and wanderings.<br><br>
    I hope every page you turn feels like home,<br>
    every word you read feels sweet as honey,
    and every story you enjoy remind you how much I love you.
  </p>
  <p class="note-footer">with love ♡</p>
  <hr>
</section>

<!-- READING LIST -->
<section id="list">
