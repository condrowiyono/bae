<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>For Bethany</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      min-height: 100%;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    body {
      background: #fff;
      color: #111;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 16px;
      line-height: 1.7;
      width: 100%;
      max-width: 560px;
      padding: 32px 24px 48px;
    }

    /* ── Ornament & Header ── */
    .ornament {
      text-align: center;
      font-size: 20px;
      letter-spacing: 10px;
      color: #888;
      margin-bottom: 12px;
    }

    h1 {
      font-size: 32px;
      font-weight: normal;
      text-align: center;
      letter-spacing: 0.03em;
      line-height: 1.2;
    }

    .tagline {
      text-align: center;
      font-style: italic;
      color: #555;
      font-size: 15px;
      margin-top: 6px;
      margin-bottom: 28px;
    }

    /* ── Tab radio inputs (hidden) ── */
    input[name="tab"] {
      display: none;
    }

    /* ── Navigation ── */
    nav {
      display: flex;
      border-top: 1px solid #ccc;
      border-bottom: 1px solid #ccc;
      margin-bottom: 28px;
    }

    nav label {
      flex: 1;
      text-align: center;
      padding: 10px 4px;
      color: #555;
      font-size: 13px;
      letter-spacing: 0.1em;
      font-family: Georgia, serif;
      border-bottom: 2px solid transparent;
      cursor: pointer;
    }

    /* ── Active tab label ── */
    #tab-home:checked  ~ nav label[for="tab-home"],
    #tab-list:checked  ~ nav label[for="tab-list"],
    #tab-quote:checked ~ nav label[for="tab-quote"],
    #tab-secret:checked ~ nav label[for="tab-secret"] {
      color: #111;
      border-bottom-color: #111;
    }

    /* ── Divider ── */
    hr {
      border: none;
      border-top: 1px solid #ddd;
      margin: 24px 0;
    }

    /* ── Section Label ── */
    .label {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 12px;
    }

    /* ── Sections: hidden by default, shown via checked radio ── */
    section {
      display: none;
    }

    #tab-home:checked  ~ #home,
    #tab-list:checked  ~ #list,
    #tab-quote:checked ~ #quote,
    #tab-secret:checked ~ #secret {
      display: block;
    }

    /* ── Home ── */
    #home {
      padding: 0 16px;
    }

    /* ── Love Note ── */
    .note {
      font-style: italic;
      font-size: 17px;
      line-height: 1.85;
      color: #222;
    }

    .note-footer {
      margin-top: 20px;
      font-size: 14px;
      color: #555;
      text-align: right;
    }

    /* ── Reading List ── */
    .book {
      display: flex;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid #eee;
      align-items: flex-start;
    }

    .spine {
      width: 7px;
      min-height: 52px;
      background: #222;
      border-radius: 1px;
      flex-shrink: 0;
      margin-top: 4px;
    }

    .book-title {
      font-size: 16px;
      font-weight: bold;
      line-height: 1.3;
      margin-bottom: 4px;
    }

    .book-author {
      font-size: 13px;
      color: #555;
      font-style: italic;
    }

    .book-note {
      font-size: 12px;
      color: #888;
      margin-top: 4px;
    }

    .amazon-btn {
      display: inline-block;
      margin-top: 8px;
      padding: 8px 16px;
      background: #111;
      color: #fff;
      font-family: Georgia, serif;
      font-size: 13px;
      text-decoration: none;
      letter-spacing: 0.05em;
      border: none;
      cursor: pointer;
    }

    .amazon-btn:hover {
      background: #333;
    }

    /* ── Quote ── */
    blockquote {
      border-left: 2px solid #333;
      padding: 4px 0 4px 18px;
      margin: 0 0 12px;
    }

    blockquote p {
      font-style: italic;
      font-size: 17px;
      line-height: 1.75;
      color: #222;
    }

    .quote-source {
      font-size: 13px;
      color: #666;
      margin-top: 8px;
      padding-left: 18px;
    }

    .next-btn {
      display: block;
      width: 100%;
      text-align: center;
      margin-top: 24px;
      padding: 12px;
      border: 1px solid #333;
      background: #fff;
      font-family: Georgia, serif;
      font-size: 14px;
      cursor: pointer;
      color: #333;
      letter-spacing: 0.05em;
    }

    /* ── Hidden Message ── */
    .secret {
      font-size: 15px;
      line-height: 1.85;
      color: #222;
    }

    .secret-footer {
      margin-top: 24px;
      font-style: italic;
      font-size: 14px;
      color: #888;
      text-align: center;
    }

    /* ── Page Footer ── */
    footer {
      text-align: center;
      margin-top: 48px;
      font-size: 12px;
      color: #bbb;
      letter-spacing: 0.05em;
    }
  </style>
</head>
<body>

<div class="ornament">— ✦ —</div>
<h1>Dear My Love</h1>
<p class="tagline">a little something, made with love for you</p>

<!-- Tab state controllers — must be siblings before nav and sections -->
<input type="radio" name="tab" id="tab-home" checked />
<input type="radio" name="tab" id="tab-list" />
<input type="radio" name="tab" id="tab-quote" />
<input type="radio" name="tab" id="tab-secret" />

<nav>
  <label for="tab-home">Home</label>
  <label for="tab-list">Reading list</label>
  <label for="tab-quote">Quote</label>
  <label for="tab-secret">✦</label>
</nav>

<!-- HOME -->
<section id="home">
  <p class="label">A note for you</p>
  <p class="note">
    Every great love story begins with a book —<br>
    or so they say.<br><br>
    This Kindle is yours now.<br>
    Fill it with worlds, words, and wanderings.<br><br>
    I hope every page you turn feels like home,<br>
    every word you read feels sweet as honey,
    and every story you enjoy remind you how much I love you.
  </p>
  <p class="note-footer">with love ♡</p>
  <hr>
</section>

<!-- READING LIST -->
<section id="list">
  <p class="label">Curated for you</p>

  <div class="book">
    <div class="spine"></div>
    <div>
      <p class="book-title">More Days at the Morisaki Bookshop</p>
      <p class="book-author">Satoshi Yagisawa</p>
      <p class="book-note">handpicked, just for you ✦</p>
      <a class="amazon-btn" href="https://www.amazon.com/More-Days-Morisaki-Bookshop-Novel-ebook/dp/B0CKBV6PQG" target="_blank" rel="noopener">Read on Kindle →</a>
    </div>
  </div>

  <p class="label">Free selection</p>

  <div class="book">
    <div class="spine"></div>
    <div>
      <p class="book-title">Amazon Classic</p>
      <p class="book-author">Amazon</p>
      <p class="book-note">the best of the best</p>
      <a class="amazon-btn" href="https://www.amazon.com/b?ie=UTF8&node=18660703011" target="_blank" rel="noopener">Browse on Amazon →</a>
    </div>
  </div>

</section>

<!-- QUOTE -->
<section id="quote">
  <p class="label">Today's quote</p>
  <blockquote>
    <p id="q-text">"A reader lives a thousand lives before he dies. The man who never reads lives only one."</p>
  </blockquote>
  <p class="quote-source" id="q-src">— George R.R. Martin</p>
  <button class="next-btn" id="next-quote-btn">next quote →</button>
</section>

<!-- SECRET -->
<section id="secret">
  <p class="label">You found it ✦</p>
  <p class="secret">
    You pressed the little star tab.<br>
    Of course you did.<br><br>
    That curiosity -- i love it<br>
    it's one of the hundred things I love about you. <br><br>
    Happy birthday, my love.<br>
    Here's to all the pages ahead of us.
  </p>
  <p class="secret-footer">— yours, always ♡</p>
</section>

<footer>bae.condro.me &nbsp;·&nbsp; made with love</footer>

<script>
  const quotes = [
    { t: '"A reader lives a thousand lives before he dies. The man who never reads lives only one."', s: '— George R.R. Martin' },
    { t: '"All good books are alike in that they are truer than if they had really happened."', s: '— Ernest Hemingway, "Old Newsman Writes"' },
    { t: '"A book is a dream that you hold in your hands."', s: '— Neil Gaiman' },
    { t: '"Books are a uniquely portable magic."', s: '— Stephen King' },
    { t: '"Until I feared I would lose it, I never loved to read. One does not love breathing."', s: '— Harper Lee' },
    { t: '"She is too fond of books, and it has turned her brain."', s: '— Louisa May Alcott' },
    { t: '"Not all those who wander are lost."', s: '— J.R.R. Tolkien' },
    { t: '"And, when you want something, all the universe conspires in helping you to achieve it."', s: '— Paulo Coelho, The Alchemist' },
    { t: '"One is loved because one is loved. No reason is needed for loving."', s: '— Paulo Coelho, The Alchemist' },
    { t: '"Hidup adalah perjalanan panjang menuju rumah."', s: '— Dee Lestari, Perahu Kertas' },
    { t: '"Cinta bukan soal menemukan orang yang sempurna, tapi belajar melihat dengan sempurna orang yang tidak sempurna."', s: '— Dee Lestari, Supernova' },
    { t: '"It does not do to dwell on dreams and forget to live."', s: '— Albus Dumbledore, Harry Potter' },
    { t: '"Happiness can be found, even in the darkest of times, if one only remembers to turn on the light."', s: '— Albus Dumbledore, Harry Potter' },
    { t: '"You can never get a cup of tea large enough or a book long enough to suit me."', s: '— C.S. Lewis' },
    { t: '"We read to know we are not alone."', s: '— William Nicholson, Shadowlands' },
    { t: '"The happiness of your life depends upon the quality of your thoughts."', s: '— Marcus Aurelius, Meditations, VI.16' },
    { t: '"We suffer more often in imagination than in reality."', s: '— Seneca' },
    { t: '"How wonderful it is that nobody need wait a single moment before starting to improve the world."', s: '— Anne Frank, The Diary of a Young Girl' },
    { t: '"Think of all the beauty still left around you and be happy."', s: '— Anne Frank, The Diary of a Young Girl' },
    { t: '"It is easy to mourn the lives we aren\u2019t living. It is easy to wish we were somewhere else. It is easy to regret. The hardest thing is to be here. Right here."', s: '— Matt Haig, The Midnight Library' },
  ];

  let qi = 0;

  document.getElementById('next-quote-btn')?.addEventListener('click', () => {
    qi = (qi + 1) % quotes.length;
    document.getElementById('q-text')!.textContent = quotes[qi].t;
    document.getElementById('q-src')!.textContent = quotes[qi].s;
  });
</script>

</body>
</html>
